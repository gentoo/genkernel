%begin append_base_layout
	isTrue "${UNIONFS}" && build_parameters+=( --unionfs ) || build_parameters+=( --no-unionfs )
%end append_base_layout

-----

%begin create_initramfs
	append_data 'unionfs_fuse' "${UNIONFS}"
%end create_initramfs

-----

%begin determine_real_args
	set_config_with_override BOOL   UNIONFS                               CMD_UNIONFS                               "no"
%end determine_real_args

-----

%begin genkernel_conf
# Include support for unionfs
#UNIONFS="no"
%end genkernel_conf

-----

%begin initramfs_append_func
append_unionfs_fuse() {
	local PN=unionfs-fuse
	local TDIR="${TEMP}/initramfs-${PN}-temp"
	if [ -d "${TDIR}" ]
	then
		rm -r "${TDIR}" || gen_die "Failed to clean out existing '${TDIR}'!"
	fi

	populate_binpkg ${PN}

	mkdir -p "${TDIR}" || gen_die "Failed to create '${TDIR}'!"

	unpack "$(get_gkpkg_binpkg "${PN}")" "${TDIR}"

	cd "${TDIR}" || gen_die "Failed to chdir to '${TDIR}'!"
	log_future_cpio_content
	find . -print0 | "${CPIO_COMMAND}" ${CPIO_ARGS} --append -F "${CPIO_ARCHIVE}" \
		|| gen_die "Failed to append ${PN} to cpio!"

	cd "${TEMP}" || die "Failed to chdir to '${TEMP}'!"
	if isTrue "${CLEANUP}"
	then
		rm -rf "${TDIR}"
	fi
}
%end initramfs_append_func

-----

%begin longusage
  echo "	--unionfs		Include support for unionfs"
  echo "	--no-unionfs		Exclude support for unionfs"
%end longusage

-----

%begin man_genkernel_8
*--*[*no-*]*unionfs*::
    Includes or excludes support for unionfs.
    When enabled, this will compile unionfs-fuse for you.
%end man_genkernel_8

-----

%begin parse_cmdline
		--unionfs|--no-unionfs)
			CMD_UNIONFS=$(parse_optbool "$*")
			print_info 3 "CMD_UNIONFS: ${CMD_UNIONFS}"
			;;
%end parse_cmdline
